[Unit]
Description=DATUM Gateway (solo Stratum work from local Bitcoin Knots GBT)
After=network-online.target bitcoind.service
Wants=network-online.target
Requires=bitcoind.service

[Service]
Type=simple
User=__SERVICE_USER__
ExecStart=/usr/local/bin/datum_gateway -c /etc/blockvase/datum_gateway_config.json
Restart=on-failure
RestartSec=15

[Install]
WantedBy=multi-user.target
