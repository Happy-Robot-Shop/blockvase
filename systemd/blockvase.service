[Unit]
Description=Blockvase web portal and node monitor
After=network-online.target
Wants=network-online.target
After=bitcoind.service
Wants=bitcoind.service
After=blockvase-ap.service
Wants=blockvase-ap.service

[Service]
Type=simple
User=__SERVICE_USER__
WorkingDirectory=__PROJECT_DIR__
Environment=PYTHONUNBUFFERED=1
Environment=ENABLE_SYSTEM_ACTIONS=true
Environment=BLOCKVASE_PORT=80
ExecStart=__PROJECT_DIR__/scripts/run.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

